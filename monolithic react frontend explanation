import React, { useState, useContext } from "react";
import API from "../../api/axios";
import { useNavigate } from "react-router-dom";
import { AuthContext } from "../../Context/AuthContext";
import { Box, Paper, TextField, Button, Typography, Alert } from "@mui/material";

export default function Login() {
  // ═══════════════════════════════════════════════════════════
  // STATE MANAGEMENT
  // ═══════════════════════════════════════════════════════════
  
  // Form input state
  const [form, setForm] = useState({ 
    email: "", 
    password: "" 
  });
  
  // Error/success message state
  const [message, setMessage] = useState("");
  
  // For page navigation after successful login
  const navigate = useNavigate();
  
  // Get login function from AuthContext
  const { login } = useContext(AuthContext);

  // ═══════════════════════════════════════════════════════════
  // EVENT HANDLERS
  // ═══════════════════════════════════════════════════════════
  
  // Handle input field changes
  const handleChange = (e) => {
    // e.target.name = "email" or "password"
    // e.target.value = user input
    // Spread operator keeps other fields intact
    setForm({ 
      ...form, 
      [e.target.name]: e.target.value 
    });
  };

  // Handle form submission
  const handleSubmit = async (e) => {
    e.preventDefault();  // Prevent form's default submission
    
    try {
      // Step 1: Send login request to backend
      const res = await API.post("/auth/login", form);
      console.log("Login response:", res.data);

      // Step 2: Call login function from AuthContext
      // This saves token and user to localStorage
      // And updates AuthContext state
      login(res.data.token, {
        email: res.data.email || form.email,
        firstName: res.data.firstName,
        lastName: res.data.lastName
      });

      // Step 3: Save full profile to localStorage
      // (Used by Navbar to display user info)
      const fullName = `${res.data.firstName || ""} ${res.data.lastName || ""}`.trim();
      const profileData = {
        name: fullName || res.data.email || form.email,
        email: res.data.email || form.email
      };
      localStorage.setItem("userProfile", JSON.stringify(profileData));

      // Step 4: Navigate to dashboard
      // This redirects user to main app
      navigate("/dashboard");
      
    } catch (err) {
      // Step 5: Show error message if login fails
      setMessage(
        err.response?.data?.message || "Login failed!"
      );
    }
  };

  // ═══════════════════════════════════════════════════════════
  // RETURN JSX
  // ═══════════════════════════════════════════════════════════
  
  return (
    <Box sx={{ /* Full screen container */ }}>
      <Paper sx={{ /* Login card styling */ }}>
        
        {/* Logo and Title */}
        <Box sx={{ textAlign: 'center', mb: 4 }}>
          <Typography variant="h4">Welcome Back</Typography>
        </Box>

        {/* Login Form */}
        <Box component="form" onSubmit={handleSubmit}>
          
          {/* Email Input */}
          <TextField
            fullWidth
            label="Email Address"
            name="email"
            type="email"
            value={form.email}
            onChange={handleChange}
            required
          />

          {/* Password Input */}
          <TextField
            fullWidth
            label="Password"
            name="password"
            type="password"
            value={form.password}
            onChange={handleChange}
            required
          />

          {/* Submit Button */}
          <Button
            fullWidth
            variant="contained"
            type="submit"
          >
            Login
          </Button>

          {/* Error Message */}
          {message && <Alert severity="error">{message}</Alert>}
          
        </Box>
      </Paper>
    </Box>
  );
}
```

