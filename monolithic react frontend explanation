import { useContext } from "react";
import { AuthContext } from "../Context/AuthContext";

export const useAuth = () => {
  // Get AuthContext from provider
  const context = useContext(AuthContext);
  
  // Safety check: ensure hook is used inside AuthProvider
  if (!context) {
    throw new Error("useAuth must be used within AuthProvider");
  }
  
  // Destructure auth state and functions from context
  const { token, user, login, logout } = context;
  
  // Return organized auth state
  return {
    isLoggedIn: !!token,    // Boolean: true if token exists
    token,                  // JWT token string
    user,                   // User object {id, email, firstName, lastName}
    login,                  // Function: (token, user) => void
    logout,                 // Function: () => void
  };
};

