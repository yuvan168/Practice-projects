## Common Data Flow Patterns

### Pattern 1: Fetch List & Display

```javascript
// In ProductList.jsx component

export default function ProductList() {
  // STEP 1: Initialize state to store products
  const [products, setProducts] = useState([])
  const [loading, setLoading] = useState(true)
  const [error, setError] = useState(null)
  
  // STEP 2: Fetch data when component mounts
  useEffect(() => {
    const fetchData = async () => {
      try {
        // Mark as loading
        setLoading(true)
        
        // STEP 3: Call API service
        // This calls: api.get("/products")
        // Axios automatically adds JWT token
        const data = await ProductService.getAllProducts()
        
        // STEP 4: Update state with data
        setProducts(data)  // [{id:1, name:"Laptop", ...}, ...]
        
        // STEP 5: Clear any previous errors
        setError(null)
        
      } catch (err) {
        // Handle errors
        setError(err.message || "Failed to load products")
        setProducts([])  // Clear products on error
        
      } finally {
        // Stop loading regardless of success/failure
        setLoading(false)
      }
    };
    
    // Call fetch function
    fetchData();
    
  }, []);  // Empty dependency array = run once on mount
  
  // STEP 6: Conditional rendering based on state
  
  if (loading) {
    return <div>Loading products...</div>
  }
  
  if (error) {
    return <div>Error: {error}</div>
  }
  
  if (products.length === 0) {
    return <div>No products found</div>
  }
  
  // STEP 7: Render products list
  return (
    <div>
      <h1>Products ({products.length})</h1>
      <table>
        <thead>
          <tr>
            <th>Name</th>
            <th>Price</th>
            <th>Quantity</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {products.map(product => (
            <tr key={product.id}>
              <td>{product.name}</td>
              <td>${product.price}</td>
              <td>{product.quantity}</td>
              <td>
                <button>Edit</button>
                <button>Delete</button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  );
}
```

