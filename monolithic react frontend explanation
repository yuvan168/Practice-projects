### 3. Authentication Context: Context/AuthContext.jsx

**File**: `src/Context/AuthContext.jsx`

```javascript
import { createContext, useState, useEffect } from "react";

// Create context object
export const AuthContext = createContext();

export const AuthProvider = ({ children }) => {
  // ═══════════════════════════════════════════════════════════
  // INITIALIZE AUTH STATE FROM LOCALSTORAGE
  // ═══════════════════════════════════════════════════════════
  
  // If user previously logged in, restore from localStorage
  const [token, setToken] = useState(localStorage.getItem("token"));
  const [user, setUser] = useState(
    JSON.parse(localStorage.getItem("user"))
  );

  // Alternative: Load from localStorage on component mount
  useEffect(() => {
    setToken(localStorage.getItem("token"));
    const savedUser = localStorage.getItem("user");
    setUser(savedUser ? JSON.parse(savedUser) : null);
  }, []);

  // ═══════════════════════════════════════════════════════════
  // LOGIN FUNCTION
  // ═══════════════════════════════════════════════════════════
  
  const login = (token, user) => {
    // 1. Store token in localStorage (persistent storage)
    localStorage.setItem("token", token);
    
    // 2. Store user info as JSON string in localStorage
    localStorage.setItem("user", JSON.stringify(user));
    
    // 3. Update React state (causes re-render)
    setToken(token);
    setUser(user);
    
    // Now all components using AuthContext will see:
    // - AuthContext.token = JWT token string
    // - AuthContext.user = {email, firstName, lastName, ...}
  };

  // ═══════════════════════════════════════════════════════════
  // LOGOUT FUNCTION
  // ═══════════════════════════════════════════════════════════
  
  const logout = () => {
    // 1. Remove token from localStorage
    localStorage.removeItem("token");
    
    // 2. Remove user from localStorage
    localStorage.removeItem("user");
    
    // 3. Reset React state to null
    setToken(null);
    setUser(null);
    
    // Now all components using AuthContext will see:
    // - AuthContext.token = null
    // - AuthContext.user = null
    // This triggers ProtectedRoute to redirect to login
  };

  // ═══════════════════════════════════════════════════════════
  // PROVIDE CONTEXT TO CHILDREN
  // ═══════════════════════════════════════════════════════════
  
  return (
    <AuthContext.Provider value={{ token, user, login, logout }}>
      {children}  {/* All components wrapped by AuthProvider */}
    </AuthContext.Provider>
  );
};
```

**State Persistence Flow**:
```
User Logs In
  ↓
login(token, user) called
  ├── localStorage.setItem("token", token)
  ├── localStorage.setItem("user", user)
  ├── setToken(token)
  └── setUser(user)
  ↓
User Refreshes Page
  ↓
App.jsx mounts again
  ├── AuthProvider loads from localStorage
  ├── setToken(localStorage.getItem("token"))
  └── setUser(localStorage.getItem("user"))
  ↓
User is Still Logged In (state restored!)
```

