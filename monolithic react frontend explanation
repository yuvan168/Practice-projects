## Key Services & Utilities

### ProductService.js - Complete API Service Layer

**Purpose**: Centralized API communication layer for all backend requests.

```javascript
import api from "../api/axios";

export default {
  // ═══════════════════════════════════════
  // PRODUCT CRUD OPERATIONS
  // ═══════════════════════════════════════
  
  getAllProducts: () => 
    api.get("/products")           // HTTP GET request to backend
      .then((res) => res.data),    // Extract data from Axios response
    // URL: http://localhost:8088/api/products
    // Returns: [{id, name, price, quantity, manufacturer, ...}, ...]
    // Used in: ProductList.jsx (on component mount)
  
  getProduct: (id) => 
    api.get(`/products/${id}`)     // Dynamic URL with product ID
      .then((res) => res.data),
    // URL: http://localhost:8088/api/products/123
    // Returns: {id, name, price, quantity, manufacturer, ...}
    // Used in: EditProduct.jsx (fetch product to populate form)
  
  addProduct: (product) => 
    api.post(
      "/products",               // POST request to create
      product                    // Body contains new product data
    ).then((res) => res.data),
    // URL: http://localhost:8088/api/products
    // Body: {name: "Laptop", price: 999, quantity: 5, manufacturer: "Dell"}
    // Returns: {id: 1, name, price, quantity, manufacturer, createdDate, ...}
    // Used in: AddProduct.jsx (form submission)
  
  updateProduct: (id, product) =>
    api.put(
      `/products/${id}`,         // PUT request to specific product
      product                    // Updated product data
    ).then((res) => res.data),
    // URL: http://localhost:8088/api/products/123
    // Body: {name: "Laptop Pro", price: 1299, quantity: 3, manufacturer: "Dell"}
    // Returns: updated product object
    // Used in: EditProduct.jsx (form submission)
  
  deleteProduct: (id) => 
    api.delete(`/products/${id}`),  // DELETE request to remove product
    // URL: http://localhost:8088/api/products/123
    // Returns: { success: true } or empty response with 200 status
    // Used in: ProductList.jsx (delete button click)
  
  // ═══════════════════════════════════════
  // AUTHENTICATION OPERATIONS
  // ═══════════════════════════════════════
  
  register: (user) => 
    api.post(
      "/auth/signup",            // Create new user account
      user                       // Registration data
    ).then((res) => res.data),
    // URL: http://localhost:8088/api/auth/signup
    // Body: {email: "user@test.com", password: "pass123", firstName: "John", lastName: "Doe"}
    // Returns: {token: "eyJhbGc...", email, firstName, lastName, ...}
    // Used in: Register.jsx
  
  login: (credentials) =>
    api.post(
      "/auth/login",             // Authenticate user
      credentials                // Email & password
    ).then((res) => res.data),
