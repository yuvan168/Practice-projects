### Pattern 2: Form Submission with Validation

```javascript
// In AddProduct.jsx

export default function AddProduct() {
  const navigate = useNavigate()
  const [submitError, setSubmitError] = useState(null)
  
  // STEP 1: Use Formik for form state management
  const formik = useFormik({
    // Initial values when form loads
    initialValues: {
      name: '',
      price: '',
      quantity: '',
      manufacturer: '',
    },
    
    // STEP 2: Define validation rules using Yup
    validationSchema: Yup.object({
      name: Yup.string()
        .required('Product name is required')
        .min(3, 'Name must be at least 3 characters'),
      price: Yup.number()
        .required('Price is required')
        .min(0, 'Price cannot be negative'),
      quantity: Yup.number()
        .required('Quantity is required')
        .min(0, 'Quantity cannot be negative'),
      manufacturer: Yup.string()
        .required('Manufacturer is required'),
    }),
    
    // STEP 3: Handle form submission
    onSubmit: async (values) => {
      try {
        // Call API to add product
        // Axios adds JWT token automatically
        const newProduct = await ProductService.addProduct(values)
        
        // Show success message
        toast.success('Product added successfully!')
        
        // Navigate back to products list
        navigate('/products')
        
      } catch (error) {
        // Show error message
        const message = error.response?.data?.message || 'Failed to add product'
        setSubmitError(message)
        toast.error(message)
      }
    },
  })
  
  // STEP 4: Render form with Formik inputs
  return (
    <form onSubmit={formik.handleSubmit}>
      {submitError && <Alert severity="error">{submitError}</Alert>}
      
      {/* Product Name Field */}
      <TextField
        label="Product Name"
        name="name"
        value={formik.values.name}
        onChange={formik.handleChange}
        onBlur={formik.handleBlur}
        // Show error if field was touched AND has error
        error={formik.touched.name && Boolean(formik.errors.name)}
        helperText={formik.touched.name && formik.errors.name}
      />
      
      {/* Submit Button - disabled until form is valid */}
      <Button
        type="submit"
        variant="contained"
        disabled={!formik.isValid || formik.isSubmitting}
      >
        {formik.isSubmitting ? 'Adding...' : 'Add Product'}
      </Button>
    </form>
  )
}
```

