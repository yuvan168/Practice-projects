### 16.6 `AuthController.java` — AUTHENTICATION APIs (Full Actual Code with Detail)

```java
package com.example.inventory.controller;

import com.example.inventory.dto.*;
import com.example.inventory.entity.Role;
import com.example.inventory.entity.User;
import com.example.inventory.repository.RoleRepository;
import com.example.inventory.repository.UserRepository;
import com.example.inventory.security.JwtUtils;
import jakarta.validation.Valid;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.ResponseEntity;
import org.springframework.security.authentication.AuthenticationManager;
import org.springframework.security.authentication.UsernamePasswordAuthenticationToken;
import org.springframework.security.core.Authentication;
import org.springframework.security.core.context.SecurityContextHolder;
import org.springframework.security.crypto.password.PasswordEncoder;
import org.springframework.web.bind.annotation.*;

import java.util.HashSet;
import java.util.List;
import java.util.Set;
import java.util.stream.Collectors;

@RestController           // ← This class handles HTTP requests and returns JSON
@RequestMapping("/api/auth")  // ← All methods in this class start with "/api/auth"
public class AuthController {

    private static final Logger logger = LoggerFactory.getLogger(AuthController.class);

    @Autowired private AuthenticationManager authenticationManager;
    // ↑ From SecurityConfig — used to verify email+password during login

    @Autowired private UserRepository userRepository;
    // ↑ Access to users table

    @Autowired private RoleRepository roleRepository;
    // ↑ Access to roles table

    @Autowired private PasswordEncoder passwordEncoder;
    // ↑ BCrypt encoder from SecurityConfig

    @Autowired private JwtUtils jwtUtils;
    // ↑ JWT utility for generating tokens

    // ═══════════════════════════════════════════════════════════
    // SIGNUP — Register a new user account
    // URL: POST http://localhost:8088/api/auth/signup
    // Auth: NOT REQUIRED (public endpoint)
    // ═══════════════════════════════════════════════════════════
    @PostMapping("/signup")
    public ResponseEntity<?> registerUser(@Valid @RequestBody SignupRequest signupRequest) {
        // @Valid → triggers validation on SignupRequest (@NotBlank, @Email)
        //          If validation fails → Spring returns 400 with error messages automatically
        // @RequestBody → parses JSON body: {"firstName":"John","lastName":"Doe","email":"...","password":"..."}

        logger.debug("Signup request received for email: {}", signupRequest.getEmail());

        // ─── Check if email already exists ───
        if (userRepository.existsByEmail(signupRequest.getEmail())) {
            return ResponseEntity.badRequest()
                    .body(new MessageResponse("Email already exists"));
            // HTTP 400: {"message": "Email already exists"}
        }

        // ─── Create new User entity ───
        User user = new User();
        user.setFirstName(signupRequest.getFirstName());
        user.setLastName(signupRequest.getLastName());
        user.setEmail(signupRequest.getEmail());
        user.setPassword(passwordEncoder.encode(signupRequest.getPassword()));
        // ↑ CRITICAL: Never store plain passwords!
        //   "password123" → "$2a$10$N9qo8uLOickgx2ZMRZoMye..."
        //   BCrypt adds random salt so same password → different hash each time

        // ─── Assign default role ───
        Set<Role> roles = new HashSet<>();
        Role userRole = roleRepository.findByName("ROLE_USER")
                .orElseGet(() -> {
                    // If "ROLE_USER" doesn't exist in DB yet, create it
                    Role newRole = new Role();
                    newRole.setName("ROLE_USER");
                    return roleRepository.save(newRole);
                    // INSERT INTO roles (name) VALUES ('ROLE_USER')
                });
        roles.add(userRole);
        user.setRoles(roles);
        // This creates entry in user_roles junction table

        // ─── Save to database ───
        userRepository.save(user);
        // INSERT INTO users (first_name, last_name, email, password) VALUES (?, ?, ?, ?)
        // INSERT INTO user_roles (user_id, role_id) VALUES (?, ?)

        logger.info("User registered successfully: {}", signupRequest.getEmail());

        return ResponseEntity.ok(new MessageResponse("User registered successfully"));
        // HTTP 200: {"message": "User registered successfully"}
    }

    // ═══════════════════════════════════════════════════════════
    // LOGIN — Authenticate and get JWT token
    // URL: POST http://localhost:8088/api/auth/login
    // Auth: NOT REQUIRED (public endpoint)
    // ═══════════════════════════════════════════════════════════
    @PostMapping("/login")
    public ResponseEntity<?> authenticateUser(@Valid @RequestBody LoginRequest loginRequest) {
        // JSON body: {"email": "user@email.com", "password": "password123"}

        logger.debug("Login request received for email: {}", loginRequest.getEmail());

        // ─── Authenticate credentials ───
        Authentication authentication = authenticationManager.authenticate(
                new UsernamePasswordAuthenticationToken(
                        loginRequest.getEmail(),
                        loginRequest.getPassword()
                )
        );
        // ↑ THIS IS WHERE THE MAGIC HAPPENS:
        // 1. AuthenticationManager calls DaoAuthenticationProvider
        // 2. DaoAuthenticationProvider calls CustomUserDetailsService.loadUserByUsername(email)
        // 3. CustomUserDetailsService queries DB: SELECT * FROM users WHERE email = ?
        // 4. DaoAuthenticationProvider calls BCrypt.matches(providedPassword, storedHash)
        // 5. If password matches → returns Authentication object (success!)
        // 6. If password doesn't match → throws BadCredentialsException → Spring returns 401

        // ─── Set authentication in security context ───
        SecurityContextHolder.getContext().setAuthentication(authentication);

        // ─── Generate JWT token ───
        String jwt = jwtUtils.generateJwtToken(authentication);
        // Creates token with: subject=email, issuedAt=now, expiration=now+24h
        // Signs with HMAC-SHA256 secret key

        // ─── Get user info for response ───
        User user = userRepository.findByEmail(loginRequest.getEmail())
                .orElseThrow(() -> new RuntimeException("User not found"));

        logger.info("Login successful for user: {}", loginRequest.getEmail());

        // ─── Return token + user info ───
        return ResponseEntity.ok(new LoginResponse(
                jwt,                  // The JWT token string
                user.getEmail(),      // Email
                user.getFirstName(),  // First name
                user.getLastName()    // Last name
        ));
        // HTTP 200: {"token": "eyJhbG...", "email": "user@email.com", "firstName": "John", "lastName": "Doe"}
        // Frontend stores this token in localStorage and sends it with every future request
    }

    // ═══════════════════════════════════════════════════════════
    // GET PROFILE — Get current user's info
    // URL: GET http://localhost:8088/api/auth/profile
    // Auth: REQUIRED (must have valid JWT)
    // ═══════════════════════════════════════════════════════════
    @GetMapping("/profile")
    public ResponseEntity<?> getProfile() {
        // By the time we reach here:
        // 1. JwtFilter already validated the token
        // 2. JwtFilter set Authentication in SecurityContext
        // So we can now read WHO is making this request:

        Authentication auth = SecurityContextHolder.getContext().getAuthentication();
        String email = auth.getName();  // Gets the email from the JWT token's subject

        User user = userRepository.findByEmail(email)
                .orElseThrow(() -> new RuntimeException("User not found"));

        return ResponseEntity.ok(new LoginResponse(null, user.getEmail(), user.getFirstName(), user.getLastName()));
        // token=null because we're not generating a new token (user already has one)
    }

    // ═══════════════════════════════════════════════════════════
    // UPDATE PROFILE — Modify current user's info
    // URL: PUT http://localhost:8088/api/auth/profile
    // Auth: REQUIRED
    // ═══════════════════════════════════════════════════════════
    @PutMapping("/profile")
    public ResponseEntity<?> updateProfile(@RequestBody SignupRequest updateRequest) {
        Authentication auth = SecurityContextHolder.getContext().getAuthentication();
        String email = auth.getName();

        User user = userRepository.findByEmail(email)
                .orElseThrow(() -> new RuntimeException("User not found"));

        // Only update fields that are sent (partial update)
        if (updateRequest.getFirstName() != null) user.setFirstName(updateRequest.getFirstName());
        if (updateRequest.getLastName() != null) user.setLastName(updateRequest.getLastName());
        if (updateRequest.getPassword() != null && !updateRequest.getPassword().isBlank()) {
            user.setPassword(passwordEncoder.encode(updateRequest.getPassword()));
            // Re-hash the new password before saving
        }

        userRepository.save(user);
        // UPDATE users SET first_name=?, last_name=?, password=? WHERE id=?

        return ResponseEntity.ok(new MessageResponse("Profile updated successfully"));
    }

    // ═══════════════════════════════════════════════════════════
    // GET ALL USERS — List all registered users
    // URL: GET http://localhost:8088/api/auth/users
    // Auth: REQUIRED
    // ═══════════════════════════════════════════════════════════
    @GetMapping("/users")
    public ResponseEntity<?> getAllUsers() {
        List<User> users = userRepository.findAll();
        // SELECT * FROM users

        List<LoginResponse> response = users.stream()
                .map(u -> new LoginResponse(null, u.getEmail(), u.getFirstName(), u.getLastName()))
                .collect(Collectors.toList());
        // Convert User entities to DTOs (hides password from response)

        return ResponseEntity.ok(response);
        // HTTP 200: [{"token":null,"email":"...","firstName":"...","lastName":"..."}, ...]
    }

    // ═══════════════════════════════════════════════════════════
    // CREATE USER — Admin creates a new user
    // URL: POST http://localhost:8088/api/auth/users
    // Auth: REQUIRED
    // ═══════════════════════════════════════════════════════════
    @PostMapping("/users")
    public ResponseEntity<?> createUser(@Valid @RequestBody SignupRequest request) {
        if (userRepository.existsByEmail(request.getEmail())) {
            return ResponseEntity.badRequest().body(new MessageResponse("Email already exists"));
        }

        User user = new User();
        user.setFirstName(request.getFirstName());
        user.setLastName(request.getLastName());
        user.setEmail(request.getEmail());
        user.setPassword(passwordEncoder.encode(request.getPassword()));

        Set<Role> roles = new HashSet<>();
        Role userRole = roleRepository.findByName("ROLE_USER")
                .orElseGet(() -> {
                    Role newRole = new Role();
                    newRole.setName("ROLE_USER");
                    return roleRepository.save(newRole);
                });
        roles.add(userRole);
        user.setRoles(roles);

        userRepository.save(user);
        return ResponseEntity.ok(new MessageResponse("User created successfully"));
    }

    // ═══════════════════════════════════════════════════════════
    // UPDATE USER BY ID
    // URL: PUT http://localhost:8088/api/auth/users/5
    // Auth: REQUIRED
    // ═══════════════════════════════════════════════════════════
    @PutMapping("/users/{id}")
    public ResponseEntity<?> updateUser(@PathVariable Long id, @RequestBody SignupRequest request) {
        // @PathVariable → extracts "5" from URL "/api/auth/users/5" → id = 5L

        User user = userRepository.findById(id)
                .orElseThrow(() -> new RuntimeException("User not found"));
        // SELECT * FROM users WHERE id = 5

        if (request.getFirstName() != null) user.setFirstName(request.getFirstName());
        if (request.getLastName() != null) user.setLastName(request.getLastName());
        if (request.getEmail() != null) user.setEmail(request.getEmail());
        if (request.getPassword() != null && !request.getPassword().isBlank()) {
            user.setPassword(passwordEncoder.encode(request.getPassword()));
        }

        userRepository.save(user);
        return ResponseEntity.ok(new MessageResponse("User updated successfully"));
    }

    // ═══════════════════════════════════════════════════════════
    // DELETE USER
    // URL: DELETE http://localhost:8088/api/auth/users/5
    // Auth: REQUIRED
    // ═══════════════════════════════════════════════════════════
    @DeleteMapping("/users/{id}")
    public ResponseEntity<?> deleteUser(@PathVariable Long id) {
        userRepository.deleteById(id);
        // DELETE FROM user_roles WHERE user_id = 5
        // DELETE FROM users WHERE id = 5
        return ResponseEntity.ok(new MessageResponse("User deleted successfully"));
    }
}
