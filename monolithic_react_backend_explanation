```java
package com.example.inventory.security;

import com.example.inventory.entity.User;
import com.example.inventory.repository.UserRepository;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.security.core.authority.SimpleGrantedAuthority;
import org.springframework.security.core.userdetails.UserDetails;
import org.springframework.security.core.userdetails.UserDetailsService;
import org.springframework.security.core.userdetails.UsernameNotFoundException;
import org.springframework.stereotype.Service;

import java.util.stream.Collectors;

@Service  // ← Marks this as a Spring service bean (auto-detected by component scan)
public class CustomUserDetailsService implements UserDetailsService {
    // ↑ Implements Spring Security's interface
    //   Spring Security calls loadUserByUsername() whenever it needs user info

    @Autowired
    private UserRepository userRepository;
    // ↑ Injected: provides access to the users table

    @Override
    public UserDetails loadUserByUsername(String email) throws UsernameNotFoundException {
        // ─── Called in TWO places: ───
        // 1. JwtAuthenticationFilter → after extracting email from token
        // 2. DaoAuthenticationProvider → during login authentication

        // ─── Query database for user ───
        User user = userRepository.findByEmail(email)
                .orElseThrow(() -> new UsernameNotFoundException("User not found with email: " + email));
        // SQL: SELECT * FROM users u LEFT JOIN user_roles ur ON u.id = ur.user_id
        //      LEFT JOIN roles r ON ur.role_id = r.id WHERE u.email = ?
        // If user doesn't exist → throws exception → authentication fails

        // ─── Convert OUR User entity to Spring Security's UserDetails ───
        return new org.springframework.security.core.userdetails.User(
                user.getEmail(),       // username (Spring Security uses "username" — we use email)
                user.getPassword(),    // BCrypt hashed password (for login verification)
                user.getRoles().stream()
                        .map(role -> new SimpleGrantedAuthority(role.getName()))
                        // Converts: Set<Role> → List<GrantedAuthority>
                        // e.g., Role{name="ROLE_USER"} → SimpleGrantedAuthority("ROLE_USER")
                        .collect(Collectors.toList())
        );
        // The returned UserDetails is used by:
        // - AuthenticationProvider: compares password hash during login
        // - JwtFilter: creates authentication token with authorities/roles
    }
}
```

**Who calls this service and why:**

| Caller | When | Why |
|--------|------|-----|
| `DaoAuthenticationProvider` | During login (`/api/auth/login`) | To load user + compare password hash |
| `JwtAuthenticationFilter` | On every authenticated request | To load user roles after token validation |

