                        //    3. @ComponentScan — scans com.example.inventory.* for annotated classes
public class InventoryBackendApplication {
    public static void main(String[] args) {
        SpringApplication.run(InventoryBackendApplication.class, args);
        // ↑ This triggers the entire Spring Boot startup:
        //   - Creates ApplicationContext (the container for all beans)
        //   - Scans and registers all @Controller, @Service, @Repository, @Component, @Configuration
        //   - Connects to MySQL using properties from application.properties
