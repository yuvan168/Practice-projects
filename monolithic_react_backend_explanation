package com.example.inventory.controller;

import com.example.inventory.entity.Product;
import com.example.inventory.repository.ProductRepository;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.*;

import java.util.List;

@RestController               // Returns JSON responses
@RequestMapping("/api/products")  // Base path: /api/products
public class ProductController {

    @Autowired
    private ProductRepository productRepository;
    // ↑ Spring injects the repository (provides DB access)

    // ═══════════════════════════════════════════════════════════
    // GET ALL PRODUCTS
    // URL: GET http://localhost:8088/api/products
    // Auth: REQUIRED (JWT token must be in header)
    // Response: Array of all products
    // ═══════════════════════════════════════════════════════════
    @GetMapping
    public ResponseEntity<List<Product>> getAllProducts() {
        return ResponseEntity.ok(productRepository.findAll());
        // findAll() → SELECT * FROM products
        // ResponseEntity.ok() → HTTP 200 status
        // Spring auto-converts List<Product> to JSON array:
        // [{"id":1,"name":"Laptop","description":"...","manufacturer":"Dell","quantity":10,"price":999.99}, ...]
    }

    // ═══════════════════════════════════════════════════════════
    // GET SINGLE PRODUCT
    // URL: GET http://localhost:8088/api/products/3
    // Auth: REQUIRED
    // Response: Single product object
    // ═══════════════════════════════════════════════════════════
    @GetMapping("/{id}")
    public ResponseEntity<Product> getProduct(@PathVariable Long id) {
        // @PathVariable → /api/products/3 → id = 3

        Product product = productRepository.findById(id)
                .orElseThrow(() -> new RuntimeException("Product not found"));
        // SELECT * FROM products WHERE id = 3
        // If not found → throws RuntimeException → Spring returns 500

        return ResponseEntity.ok(product);
        // HTTP 200: {"id":3,"name":"Monitor","description":"27 inch","manufacturer":"LG","quantity":5,"price":350.00}
    }

    // ═══════════════════════════════════════════════════════════
    // CREATE PRODUCT
    // URL: POST http://localhost:8088/api/products
    // Auth: REQUIRED
    // Body: {"name":"Keyboard","description":"Mechanical","manufacturer":"Corsair","quantity":50,"price":89.99}
    // Response: The created product (with generated ID)
    // ═══════════════════════════════════════════════════════════
    @PostMapping
    public ResponseEntity<Product> createProduct(@RequestBody Product product) {
        // @RequestBody → parses JSON body into Product object
        // product.id will be null (auto-generated by database)

        return ResponseEntity.ok(productRepository.save(product));
        // save() with null id → INSERT INTO products (name, description, manufacturer, quantity, price)
        //                        VALUES ('Keyboard', 'Mechanical', 'Corsair', 50, 89.99)
        // Returns the saved product WITH the auto-generated id:
        // HTTP 200: {"id":4,"name":"Keyboard","description":"Mechanical","manufacturer":"Corsair","quantity":50,"price":89.99}
    }

    // ═══════════════════════════════════════════════════════════
    // UPDATE PRODUCT
    // URL: PUT http://localhost:8088/api/products/4
    // Auth: REQUIRED
    // Body: {"name":"Keyboard Pro","price":129.99} (partial update allowed)
    // Response: The updated product
    // ═══════════════════════════════════════════════════════════
    @PutMapping("/{id}")
    public ResponseEntity<Product> updateProduct(@PathVariable Long id, @RequestBody Product product) {
        // First, find the existing product
        Product existing = productRepository.findById(id)
                .orElseThrow(() -> new RuntimeException("Product not found"));
        // SELECT * FROM products WHERE id = 4

        // PARTIAL UPDATE: Only update fields that are provided (not null)
        if (product.getName() != null) existing.setName(product.getName());
        if (product.getDescription() != null) existing.setDescription(product.getDescription());
        if (product.getManufacturer() != null) existing.setManufacturer(product.getManufacturer());
        if (product.getQuantity() != null) existing.setQuantity(product.getQuantity());
        if (product.getPrice() != null) existing.setPrice(product.getPrice());
        // If frontend only sends {"price": 129.99}, only price changes
        // Other fields remain unchanged

        return ResponseEntity.ok(productRepository.save(existing));
        // save() with existing id → UPDATE products SET name=?, description=?, ... WHERE id=4
        // HTTP 200: {"id":4,"name":"Keyboard Pro","description":"Mechanical","manufacturer":"Corsair","quantity":50,"price":129.99}
    }

    // ═══════════════════════════════════════════════════════════
    // DELETE PRODUCT
    // URL: DELETE http://localhost:8088/api/products/4
    // Auth: REQUIRED
    // Response: Empty 200 OK
    // ═══════════════════════════════════════════════════════════
    @DeleteMapping("/{id}")
    public ResponseEntity<?> deleteProduct(@PathVariable Long id) {
        productRepository.deleteById(id);
        // DELETE FROM products WHERE id = 4
        // If id doesn't exist → throws EmptyResultDataAccessException

        return ResponseEntity.ok().build();
        // HTTP 200 with empty body
    }
}
