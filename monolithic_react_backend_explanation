### 16.2 `SecurityConfig.java` — THE GATEKEEPER (Full Actual Code)

```java
package com.example.inventory.config;

import com.example.inventory.security.CustomUserDetailsService;
import com.example.inventory.security.JwtAuthenticationFilter;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.context.annotation.Bean;
import org.springframework.context.annotation.Configuration;
import org.springframework.security.authentication.AuthenticationManager;
import org.springframework.security.authentication.dao.DaoAuthenticationProvider;
import org.springframework.security.config.annotation.authentication.configuration.AuthenticationConfiguration;
import org.springframework.security.config.annotation.web.builders.HttpSecurity;
import org.springframework.security.config.annotation.web.configuration.EnableWebSecurity;
import org.springframework.security.config.http.SessionCreationPolicy;
import org.springframework.security.crypto.bcrypt.BCryptPasswordEncoder;
import org.springframework.security.crypto.password.PasswordEncoder;
import org.springframework.security.web.SecurityFilterChain;
import org.springframework.security.web.authentication.UsernamePasswordAuthenticationFilter;
import org.springframework.web.cors.CorsConfiguration;
import org.springframework.web.cors.CorsConfigurationSource;
import org.springframework.web.cors.UrlBasedCorsConfigurationSource;

import java.util.Arrays;
import java.util.List;

@Configuration      // ← Tells Spring: "This class contains bean definitions"
@EnableWebSecurity  // ← Activates Spring Security's web protection
public class SecurityConfig {

    @Autowired
    private CustomUserDetailsService userDetailsService;
    // ↑ Spring injects our custom user loader service

    // ═══════════════════════════════════════════════════════════
    // BEAN 1: JWT Filter — intercepts EVERY request
    // ═══════════════════════════════════════════════════════════
    @Bean
    public JwtAuthenticationFilter jwtAuthenticationFilter() {
        return new JwtAuthenticationFilter();
        // Creates an instance that will check Authorization header on every request
    }

    // ═══════════════════════════════════════════════════════════
    // BEAN 2: Password Encoder — HOW passwords are hashed
    // ═══════════════════════════════════════════════════════════
    @Bean
    public PasswordEncoder passwordEncoder() {
        return new BCryptPasswordEncoder();
        // BCrypt adds a random salt + hashes the password
        // "password123" → "$2a$10$N9qo8uLOickgx2ZMRZoMyeIjZAgcfl7p92ldGxad68LJZdL17lhWy"
        // Same password → different hash each time (because of random salt)
        // Cannot be reversed (one-way function)
    }

    // ═══════════════════════════════════════════════════════════
    // BEAN 3: Authentication Provider — WHO verifies credentials
    // ═══════════════════════════════════════════════════════════
    @Bean
    public DaoAuthenticationProvider authenticationProvider() {
        DaoAuthenticationProvider authProvider = new DaoAuthenticationProvider();
        authProvider.setUserDetailsService(userDetailsService);
        // ↑ "When you need to find a user, use THIS service" (queries DB by email)
        authProvider.setPasswordEncoder(passwordEncoder());
        // ↑ "When you need to compare passwords, use BCrypt"
        return authProvider;
        // This provider is used when AuthController calls authenticationManager.authenticate()
    }

    // ═══════════════════════════════════════════════════════════
    // BEAN 4: Authentication Manager — used by AuthController for login
    // ═══════════════════════════════════════════════════════════
    @Bean
    public AuthenticationManager authenticationManager(AuthenticationConfiguration authConfig) throws Exception {
        return authConfig.getAuthenticationManager();
        // Exposes the auth manager so AuthController can @Autowired it
        // Used in: authenticationManager.authenticate(new UsernamePasswordAuthenticationToken(email, password))
    }

    // ═══════════════════════════════════════════════════════════
    // BEAN 5: CORS Configuration — which frontends can call us
    // ═══════════════════════════════════════════════════════════
    @Bean
    public CorsConfigurationSource corsConfigurationSource() {
        CorsConfiguration configuration = new CorsConfiguration();

        configuration.setAllowedOrigins(Arrays.asList(
            "http://localhost:3000",    // React Vite dev server (default)
            "http://localhost:5173"     // React Vite alternate port
        ));
        // ↑ ONLY these origins can make API calls to us
        // Any other origin (e.g., http://evil-site.com) will be BLOCKED by browser

        configuration.setAllowedMethods(Arrays.asList(
            "GET", "POST", "PUT", "DELETE", "OPTIONS", "PATCH"
        ));
        // ↑ Which HTTP methods are allowed

        configuration.setAllowedHeaders(List.of("*"));
        // ↑ Allow ALL headers (especially "Authorization" for JWT)

        configuration.setAllowCredentials(true);
        // ↑ Allow cookies and Authorization headers

        UrlBasedCorsConfigurationSource source = new UrlBasedCorsConfigurationSource();
        source.registerCorsConfiguration("/**", configuration);
        // ↑ Apply these CORS rules to ALL URL paths
        return source;
    }

    // ═══════════════════════════════════════════════════════════
    // BEAN 6: Security Filter Chain — THE MAIN SECURITY RULES
    // ═══════════════════════════════════════════════════════════
    @Bean
    public SecurityFilterChain filterChain(HttpSecurity http) throws Exception {
        http
            .cors(cors -> cors.configurationSource(corsConfigurationSource()))
            // ↑ Apply our CORS rules (allow localhost:3000/5173)

            .csrf(csrf -> csrf.disable())
            // ↑ Disable CSRF protection
            // WHY? Because we use JWT tokens (not cookies) for auth
            // CSRF attacks exploit cookies; JWT in Authorization header is immune

            .sessionManagement(session -> session.sessionCreationPolicy(SessionCreationPolicy.STATELESS))
            // ↑ Don't create server-side sessions
            // Each request is independent — auth comes from JWT token in header
            // Server doesn't remember who you are between requests

            .authorizeHttpRequests(auth -> auth
                .requestMatchers("/api/auth/login", "/api/auth/signup", "/api/auth/register", "/error")
                    .permitAll()
                // ↑ These URLs DON'T require authentication (anyone can access)
                // Login/Signup must be public (user can't have a token before logging in!)

                .anyRequest().authenticated()
                // ↑ EVERYTHING ELSE requires a valid JWT token
                // /api/products, /api/sales, /api/auth/profile, etc.
            )

            .authenticationProvider(authenticationProvider())
            // ↑ Use our provider (UserDetailsService + BCrypt) for authentication

            .addFilterBefore(jwtAuthenticationFilter(), UsernamePasswordAuthenticationFilter.class);
            // ↑ CRITICAL: Run our JWT filter BEFORE Spring's default filter
            // Order: Request → CORS → JwtFilter → SecurityChain → Controller

        return http.build();
    }
}
```

**What this file controls:**
| Aspect | What it does |
|--------|-------------|
| CORS | Prevents unauthorized websites from calling your API |
| CSRF disabled | Because JWT tokens are used instead of cookies |
| Stateless sessions | Server doesn't store user sessions (saves memory) |
| Public endpoints | Login/Signup accessible without token |
| Private endpoints | Everything else needs JWT |
| Filter order | JWT validation happens before authorization check |

