### `JwtUtils.java` — Token Generation & Validation

```java
@Component
public class JwtUtils {

    @Value("${app.jwtSecret}")        // Reads from application.properties
    private String jwtSecret;

    @Value("${app.jwtExpirationMs}")  // 86400000 ms = 24 hours
    private long jwtExpirationMs;

    // Creates the HMAC-SHA signing key from the secret
    private SecretKey getSigningKey() {
        byte[] keyBytes = Decoders.BASE64.decode(
            Base64.getEncoder().encodeToString(jwtSecret.getBytes()));
        return Keys.hmacShaKeyFor(keyBytes);
    }

    // GENERATE TOKEN after successful login
    public String generateJwtToken(Authentication authentication) {
        UserDetails userPrincipal = (UserDetails) authentication.getPrincipal();
        return Jwts.builder()
            .subject(userPrincipal.getUsername())   // Email goes into token
            .issuedAt(new Date())                   // Current timestamp
            .expiration(new Date(System.currentTimeMillis() + jwtExpirationMs))  // +24 hours
            .signWith(getSigningKey())              // Sign with HMAC-SHA
            .compact();                            // Build token string
    }

    // EXTRACT email from token
    public String getUserNameFromJwtToken(String token) {
        return Jwts.parser()
            .verifyWith(getSigningKey())
            .build()
            .parseSignedClaims(token)
            .getPayload()
            .getSubject();   // Returns the email that was stored
    }

    // VALIDATE token (signature + expiration)
    public boolean validateJwtToken(String authToken) {
        try {
            Jwts.parser().verifyWith(getSigningKey()).build().parseSignedClaims(authToken);
            return true;  // Token is valid
        } catch (SecurityException e) { /* invalid signature */ }
          catch (MalformedJwtException e) { /* corrupted token */ }
          catch (ExpiredJwtException e) { /* token expired */ }
          catch (UnsupportedJwtException e) { /* wrong format */ }
          catch (IllegalArgumentException e) { /* empty token */ }
        return false;  // Token is invalid
    }
}
```

